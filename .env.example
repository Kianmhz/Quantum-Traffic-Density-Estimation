# Copy this file to .env and adjust values for your machine.

# Device agent
DEVICE_NAME=Home PC
PORT=8001
VIDEO_SOURCE=traffic_bi.mp4
LOOP_VIDEO=true
TARGET_FPS=12
JPEG_QUALITY=80

# Vision pipeline
MODEL_PATH=yolov8n.pt
ROWS=4
COLS=8
CONFIDENCE_THRESHOLD=0.5
YOLO_DEVICE=cuda

# Quantum options
USE_QUANTUM=false
PRECISION_QUBITS=6
SHOTS=512
QUANTUM_EVERY_N=10

# Overlay and agent behavior
DIRECTION_SPLIT=vertical
SHOW_INFO=true
START_ON_BOOT=false

# Optional Grafana push for src.pipeline --grafana
GRAFANA_URL=https://<your-grafana-host>/api/v1/push/influx/write
GRAFANA_USER=<your-grafana-user-id>
GRAFANA_TOKEN=<your-grafana-token>
